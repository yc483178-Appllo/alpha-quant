{
  "system_version": "6.0",
  "system_codename": "Alpha-Genesis",
  "feature_flags": {
    "strategy_evolution": true,
    "joinquant_data": false,
    "research_report": true,
    "knowledge_base": true,
    "smart_broker_v2": true,
    "dashboard_v3": true
  },

  "global_config": {
    "market": ["SH", "SZ"],
    "timezone": "Asia/Shanghai",
    "language": "zh-CN",
    "log_level": "INFO",
    "data_cache_ttl_seconds": 300,
    "max_retry_times": 3,
    "retry_interval_seconds": 2
  },
  "data_sources": {
    "akshare": { "enabled": true, "priority": 1, "timeout": 10 },
    "tushare": { "enabled": true, "token": "${TUSHARE_TOKEN}", "priority": 2, "timeout": 15 },
    "ths": { "enabled": true, "token": "${THS_TOKEN}", "priority": 3, "timeout": 15 },
    "baostock": { "enabled": true, "priority": 4, "timeout": 20 },
    "joinquant": { "enabled": false, "username": "${JQ_USERNAME}", "password": "${JQ_PASSWORD}", "priority": 0, "timeout": 30 }
  },
  "cache": {
    "enabled": true,
    "backend": "redis",
    "redis_url": "redis://127.0.0.1:6379/0",
    "default_ttl": 300,
    "realtime_ttl": 30,
    "history_ttl": 86400
  },
  "notification": {
    "feishu_webhook": "${FEISHU_WEBHOOK_URL}",
    "feishu_secret": "${FEISHU_SECRET}",
    "dingtalk_webhook": "${DINGTALK_WEBHOOK_URL}",
    "dingtalk_secret": "${DINGTALK_SECRET}",
    "wechat_pushplus_token": "${PUSHPLUS_TOKEN}",
    "notification_levels": {
      "daily_report": ["feishu"],
      "warning": ["feishu", "dingtalk"],
      "critical": ["feishu", "dingtalk", "wechat"]
    }
  },
  "execution": {
    "broker_type": "ptrade",
    "ptrade_host": "http://127.0.0.1:8888",
    "ptrade_token": "${PTRADE_TOKEN}",
    "max_single_order_pct": 0.05,
    "max_daily_trade_count": 10,
    "require_human_confirm": true,
    "order_timeout_seconds": 5,
    "enable_paper_trading": true
  },
  "risk": {
    "stop_loss_pct": 0.08,
    "take_profit_pct": 0.20,
    "trailing_stop_pct": 0.05,
    "max_drawdown_alert": 0.15,
    "max_position_pct": 0.20,
    "max_total_position_pct": 0.80,
    "pause_on_market_drop": 0.02,
    "daily_loss_limit_pct": 0.02,
    "consecutive_loss_days_limit": 3,
    "north_flow_alert_threshold": -80,
    "sector_concentration_limit": 0.40
  },
  "logging": {
    "log_dir": "./logs",
    "rotation": "10 MB",
    "retention": "30 days",
    "format": "{time:YYYY-MM-DD HH:mm:ss} | {level} | {module}:{function}:{line} | {message}"
  },
  "backup": {
    "enabled": true,
    "backup_dir": "./backups",
    "backup_interval_hours": 24,
    "max_backup_count": 30
  },
  "drl_portfolio": {
    "enabled": true,
    "algorithm": "transformer-ppo",
    "version": "6.0",
    "max_positions": 30,
    "feature_dim": 15,
    "d_model": 128,
    "n_heads": 4,
    "n_transformer_layers": 2,
    "transformer_model_path": "./models/transformer_drl.pt",
    "regime_aware": true,
    "fallback_to_v5_numpy": true,
    "model_save_path": "./models/drl_portfolio.npz",
    "initial_cash": 1000000,
    "transaction_cost": 0.001,
    "learning_rate": 0.0003,
    "gamma": 0.99,
    "episodes_per_retraining": 100,
    "retraining_interval_hours": 4,
    "training": {
      "n_episodes": 100,
      "auto_train": false,
      "train_schedule": "0 2 * * 0"
    },
    "inference": {
      "min_confidence": 0.6,
      "max_daily_trades": 5
    }
  },
  "sentiment_analysis": {
    "enabled": true,
    "data_sources": ["sina_finance", "eastmoney", "weibo_aggregator"],
    "update_frequency_minutes": 60,
    "lookback_days": 30,
    "time_decay_half_life_days": 7,
    "source_weights": {
      "analyst_reports": 0.6,
      "major_news": 0.3,
      "social_sentiment": 0.1
    },
    "bullish_threshold": 0.3,
    "bearish_threshold": -0.3,
    "sector_mapping": {
      "银行": ["601398", "601288", "600036", "000001"],
      "新能源": ["300750", "601012", "002594", "600438"],
      "科技": ["002415", "000725", "603501", "002236"],
      "消费": ["600519", "000858", "603288", "002714"],
      "医药": ["603259", "000538", "300760", "002007"],
      "地产": ["001979", "600048", "000002", "600383"]
    }
  },
  "portfolio_optimizer": {
    "enabled": true,
    "version": "6.0",
    "method": "regime_adaptive",
    "regime_adaptive": true,
    "regime_model_path": "./models/hmm_regime.pkl",
    "regime_update_time": "15:30",
    "method_override": null,
    "regime_method_map": {
      "bull": "momentum_tilt",
      "range": "black_litterman",
      "bear": "risk_parity",
      "crisis": "min_variance"
    },
    "risk_free_rate": 0.03,
    "hmm_enabled": true,
    "hmm_n_regimes": 4,
    "hmm_features": ["returns", "volatility", "volume_change", "rotation_speed"],
    "regime_risk_params": {
      "bull": {"max_position": 0.15, "max_sector": 0.40, "target_vol": 0.15},
      "range": {"max_position": 0.10, "max_sector": 0.30, "target_vol": 0.10},
      "bear": {"max_position": 0.08, "max_sector": 0.25, "target_vol": 0.08},
      "crisis": {"max_position": 0.05, "max_sector": 0.20, "target_vol": 0.05}
    },
    "constraints": {
      "single_stock_max_pct": 0.10,
      "sector_max_pct": 0.30,
      "min_position_count": 8,
      "max_position_count": 30,
      "min_weight": 0.02,
      "st_forbidden": true,
      "new_stock_forbidden_days": 5,
      "t_plus_1": true
    },
    "black_litterman": {
      "uncertainty_scale": 0.1,
      "confidence_in_views": 0.5
    },
    "auto_select": {
      "enabled": true,
      "high_volatility_threshold": 0.25,
      "low_volatility_threshold": 0.15
    }
  },
  "dashboard_v2": {
    "enabled": true,
    "version": "2.0",
    "host": "0.0.0.0",
    "port": 5000,
    "refresh_interval_ms": 5000,
    "websocket": {
      "enabled": false,
      "ping_interval": 25
    },
    "panels": ["overview","positions","signals","agents","strategy",
               "portfolio","sentiment","drl","risk"],
    "trading_operations": {
      "enabled": true,
      "require_guard_approval": true,
      "max_quick_trade_amount": 100000
    }
  },
  "broker_integration": {
    "enabled": true,
    "primary_broker": "ptrade",
    "fallback_brokers": ["qmt"],
    "account_configs": [
      {
        "broker": "ptrade",
        "account_id": "${PTRADE_ACCOUNT_ID}",
        "api_url": "http://localhost:8888",
        "token": ""
      },
      {
        "broker": "qmt",
        "account_id": "${QMT_ACCOUNT_ID}",
        "mini_qmt_path": "${QMT_PATH}"
      }
    ],
    "oms": {
      "enable_retry": true,
      "max_retry_attempts": 3,
      "retry_delay_seconds": 5,
      "order_timeout_seconds": 300,
      "slippage_threshold_bps": 10
    },
    "order_timeout_seconds": 5,
    "auto_retry": true,
    "max_retry_count": 3
  },
  "continuous_learning": {
    "enabled": true,
    "online_learning": {
      "enabled": true,
      "retraining_frequency": "daily",
      "lookback_days": 7,
      "exponential_avg_weight": 0.2,
      "rollback_threshold_accuracy_drop": 0.05
    },
    "ab_testing": {
      "enabled": true,
      "incumbent_allocation": 0.7,
      "challenger_allocation": 0.3,
      "promotion_threshold_pvalue": 0.05
    },
    "anomaly_detection": {
      "enabled": true,
      "baseline_window_days": 30,
      "correlation_distance_threshold": 2.0,
      "volatility_threshold_std": 2.0,
      "actions": {
        "yellow_alert": {"position_reduction_pct": 0.1},
        "red_alert": {"position_reduction_pct": 0.5, "trading_pause": true}
      }
    },
    "schedule": {
      "daily_learning_time": "15:30",
      "weekly_full_retrain": "Sunday 02:00"
    }
  },
  "strategy_evolution": {
    "enabled": true,
    "population_capacity": 100,
    "seeds_per_type": 10,
    "evolution_time": "09:00",
    "backtest_period_days": 252,
    "mutation_rate": 0.15,
    "crossover_ratio": 0.7,
    "graveyard_max_size": 500,
    "mongodb_url": "mongodb://localhost:27017/kimi_claw",
    "revival_conditions": {
      "market_regime_match": true,
      "min_historical_fitness": 5.0
    },
    "signal_weights": {
      "best_strategy": 0.4,
      "hall_of_fame_vote": 0.35,
      "top_active": 0.25
    },
    "mongodb": {
      "enabled": false,
      "uri": "mongodb://localhost:27017",
      "db_name": "alpha_evolution"
    },
    "schedule": {
      "daily_evolution_time": "15:35",
      "save_checkpoint": true
    }
  },
  "joinquant_data": {
    "enabled": false,
    "username": "",
    "password": "",
    "cache_dir": "./data/jq_cache",
    "cache_ttl_hours": 24,
    "features": {
      "fundamentals": true,
      "factors": true,
      "industry_classification": true,
      "institutional_holdings": false,
      "corporate_actions": true
    },
    "default_factors": ["alpha001", "alpha002", "momentum_1m", "value_ep", "quality_roe"]
  },
  "research_report": {
    "enabled": true,
    "output_dir": "./reports",
    "auto_generate": {
      "morning_report": "08:45",
      "closing_report": "15:35",
      "weekly_report": "Friday 16:00"
    },
    "stock_report_trigger": "on_buy_signal",
    "include_fundamentals": true,
    "include_sentiment": true,
    "pdf_export": false,
    "push_to_feishu": true
  },
  "historical_kb": {
    "enabled": true,
    "mongodb_url": "mongodb://localhost:27017/kimi_claw",
    "data_dir": "./data/knowledge_base",
    "auto_archive": true,
    "archive_time": "16:00",
    "pattern_mining_days": 180,
    "max_records_per_query": 1000
  },
  "broker_management_v2": {
    "enabled": true,
    "brokers": [
      {
        "id": "ptrade",
        "type": "ptrade",
        "name": "华泰PTrade",
        "host": "127.0.0.1",
        "port": 8888,
        "commission_rate": 0.00025
      },
      {
        "id": "qmt",
        "type": "qmt",
        "name": "迅投QMT/miniQMT",
        "path": "C:/miniQMT/bin.x64/",
        "commission_rate": 0.00030
      }
    ],
    "health_check_interval": 30,
    "auto_switch_enabled": true,
    "switch_rules": [
      {
        "id": "low_quality",
        "name": "质量评分过低自动切换",
        "condition_type": "quality_score",
        "threshold": 40.0,
        "target_broker": "qmt",
        "enabled": true,
        "priority": 10
      },
      {
        "id": "high_latency",
        "name": "延迟过高自动切换",
        "condition_type": "latency",
        "threshold": 500.0,
        "target_broker": "qmt",
        "enabled": true,
        "priority": 5
      }
    ]
  },
  "dashboard_v3": {
    "enabled": true,
    "host": "0.0.0.0",
    "port": 5001,
    "panels": [
      "live_trading_header",
      "positions",
      "signals",
      "agents",
      "evolution",
      "broker",
      "risk",
      "reports",
      "market_overview",
      "sentiment",
      "drl",
      "portfolio",
      "strategy",
      "history"
    ],
    "features": {
      "drill_down": true,
      "real_time_updates": true,
      "broker_switching": true,
      "report_preview": true
    }
  }
}
