{
  "global_config": {
    "market": ["SH", "SZ"],
    "timezone": "Asia/Shanghai",
    "language": "zh-CN",
    "log_level": "INFO",
    "data_cache_ttl_seconds": 300,
    "max_retry_times": 3,
    "retry_interval_seconds": 2
  },
  "data_sources": {
    "akshare": { "enabled": true, "priority": 1, "timeout": 10 },
    "tushare": { "enabled": true, "token": "${TUSHARE_TOKEN}", "priority": 2, "timeout": 15 },
    "ths": { "enabled": true, "token": "${THS_TOKEN}", "priority": 3, "timeout": 15 },
    "baostock": { "enabled": true, "priority": 4, "timeout": 20 }
  },
  "cache": {
    "enabled": true,
    "backend": "redis",
    "redis_url": "redis://127.0.0.1:6379/0",
    "default_ttl": 300,
    "realtime_ttl": 30,
    "history_ttl": 86400
  },
  "notification": {
    "feishu_webhook": "${FEISHU_WEBHOOK_URL}",
    "feishu_secret": "${FEISHU_SECRET}",
    "dingtalk_webhook": "${DINGTALK_WEBHOOK_URL}",
    "dingtalk_secret": "${DINGTALK_SECRET}",
    "wechat_pushplus_token": "${PUSHPLUS_TOKEN}",
    "notification_levels": {
      "daily_report": ["feishu"],
      "warning": ["feishu", "dingtalk"],
      "critical": ["feishu", "dingtalk", "wechat"]
    }
  },
  "execution": {
    "broker_type": "ptrade",
    "ptrade_host": "http://127.0.0.1:8888",
    "ptrade_token": "${PTRADE_TOKEN}",
    "max_single_order_pct": 0.05,
    "max_daily_trade_count": 10,
    "require_human_confirm": true,
    "order_timeout_seconds": 5,
    "enable_paper_trading": true
  },
  "risk": {
    "stop_loss_pct": 0.08,
    "take_profit_pct": 0.20,
    "trailing_stop_pct": 0.05,
    "max_drawdown_alert": 0.15,
    "max_position_pct": 0.20,
    "max_total_position_pct": 0.80,
    "pause_on_market_drop": 0.02,
    "daily_loss_limit_pct": 0.02,
    "consecutive_loss_days_limit": 3,
    "north_flow_alert_threshold": -80,
    "sector_concentration_limit": 0.40
  },
  "logging": {
    "log_dir": "./logs",
    "rotation": "10 MB",
    "retention": "30 days",
    "format": "{time:YYYY-MM-DD HH:mm:ss} | {level} | {module}:{function}:{line} | {message}"
  },
  "backup": {
    "enabled": true,
    "backup_dir": "./backups",
    "backup_interval_hours": 24,
    "max_backup_count": 30
  },
  "drl_portfolio": {
    "enabled": true,
    "model_save_path": "./models/drl_portfolio.npz",
    "max_positions": 30,
    "initial_cash": 1000000,
    "transaction_cost": 0.001,
    "hidden_size": 128,
    "learning_rate": 0.0003,
    "training": {
      "n_episodes": 100,
      "auto_train": false,
      "train_schedule": "0 2 * * 0"
    },
    "inference": {
      "min_confidence": 0.6,
      "max_daily_trades": 5
    }
  },
  "sentiment_analysis": {
    "enabled": true,
    "lookback_days": 30,
    "time_decay_half_life_days": 7,
    "bullish_threshold": 0.3,
    "bearish_threshold": -0.3,
    "source_weights": {
      "analyst_reports": 0.6,
      "major_news": 0.3,
      "social_sentiment": 0.1
    },
    "sector_mapping": {
      "银行": ["601398", "601288", "600036", "000001"],
      "新能源": ["300750", "601012", "002594", "600438"],
      "科技": ["002415", "000725", "603501", "002236"],
      "消费": ["600519", "000858", "603288", "002714"],
      "医药": ["603259", "000538", "300760", "002007"],
      "地产": ["001979", "600048", "000002", "600383"]
    },
    "data_sources": {
      "sina_finance": {"enabled": true, "interval_minutes": 30},
      "eastmoney_guba": {"enabled": true, "interval_minutes": 60},
      "ths_news": {"enabled": true, "interval_minutes": 60},
      "weibo_hot": {"enabled": false, "interval_minutes": 120},
      "xueqiu": {"enabled": false, "interval_minutes": 120}
    }
  },
  "portfolio_optimizer": {
    "enabled": true,
    "method": "black-litterman",
    "risk_free_rate": 0.03,
    "constraints": {
      "single_stock_max_pct": 0.10,
      "sector_max_pct": 0.30,
      "min_position_count": 8,
      "max_position_count": 30,
      "min_weight": 0.02,
      "st_forbidden": true,
      "new_stock_forbidden_days": 5,
      "t_plus_1": true
    },
    "black_litterman": {
      "uncertainty_scale": 0.1,
      "confidence_in_views": 0.5
    },
    "auto_select": {
      "enabled": true,
      "high_volatility_threshold": 0.25,
      "low_volatility_threshold": 0.15
    }
  },
  "dashboard": {
    "enabled": true,
    "version": "2.0",
    "host": "0.0.0.0",
    "port": 5000,
    "refresh_interval_seconds": 5,
    "websocket": {
      "enabled": false,
      "ping_interval": 25
    },
    "panels": {
      "overview": {"enabled": true, "position": 1},
      "portfolio": {"enabled": true, "position": 2},
      "signals": {"enabled": true, "position": 3},
      "agents": {"enabled": true, "position": 4},
      "strategies": {"enabled": true, "position": 5},
      "portfolio_analysis": {"enabled": true, "position": 6},
      "sentiment": {"enabled": true, "position": 7},
      "drl": {"enabled": true, "position": 8},
      "risk": {"enabled": true, "position": 9}
    },
    "trading": {
      "enabled": true,
      "require_guard_approval": true,
      "max_single_order_amount": 100000,
      "emergency_close_confirm": true
    }
  }
}
