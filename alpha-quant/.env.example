# Alpha Quant 环境变量配置
# 复制此文件为 .env 并填入实际值

# ==========================================
# 数据源配置
# ==========================================
TUSHARE_TOKEN=f740501c6c7e89097b32d6b9806c28f8fd62e1ea4af56629e897cca7

# ==========================================
# 通知配置（可选）
# ==========================================
# 飞书 Webhook
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# 钉钉 Webhook
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
DINGTALK_SECRET=your_dingtalk_secret

# PushPlus（微信推送）
PUSHPLUS_TOKEN=your_pushplus_token

# ==========================================
# PTrade / QMT 交易执行配置
# ==========================================

# PTrade 配置
PTRADE_TOKEN=your_ptrade_token

# QMT/miniQMT 配置
QMT_PATH=D:\国金QMT\userdata_mini  # Windows 路径示例
# QMT_PATH=/path/to/miniQMT        # Linux/Mac 路径示例
QMT_ACCOUNT_ID=your_account_id

# 交易模式: SIMULATION(模拟) / LIVE(实盘)
TRADING_MODE=SIMULATION

# ==========================================
# 信号服务器配置
# ==========================================
SIGNAL_PORT=8765
SIGNAL_SERVER_URL=http://127.0.0.1:8765

# 是否开启人工确认（模拟盘阶段建议保持 true）
REQUIRE_HUMAN_CONFIRM=true

# 信号超时时间（秒）
SIGNAL_TIMEOUT_SECONDS=60

# ==========================================
# Redis 配置（可选，默认使用本地）
# ==========================================
REDIS_URL=redis://127.0.0.1:6379/0
